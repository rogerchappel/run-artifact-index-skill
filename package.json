{
  "name": "run-artifact-index-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for indexing run artifacts into reviewable handoff evidence.",
  "type": "module",
  "bin": {
    "run-artifact-index": "./bin/run-artifact-index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node ./bin/run-artifact-index.js fixtures/sample-run --ledger fixtures/sample-run/ledger.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "bash scripts/validate.sh && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "skills",
    "artifacts",
    "handoff",
    "evidence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/run-artifact-index-skill.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/rogerchappel/run-artifact-index-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/run-artifact-index-skill#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {}
